# Copy to .codex_runtime_env/relay_control.env and fill in locally.
# Do not commit the filled file.

# SSH target for the whitelisted VPS relay host, for example:
# PUMP_RELAY_VPS_SSH_TARGET=ubuntu@example.invalid
PUMP_RELAY_VPS_SSH_TARGET=

# Private SSH key path used only for relay control.
# PUMP_RELAY_VPS_SSH_KEY=/Users/example/.ssh/pump_launch_deploy
PUMP_RELAY_VPS_SSH_KEY=

# Remote relay repository and config. Keep these on the VPS; do not put secrets here.
PUMP_RELAY_REMOTE_APP_DIR=/home/ubuntu/pump-launch-quant
PUMP_RELAY_REMOTE_CONFIG=config/local.toml
PUMP_RELAY_REMOTE_HEALTH_ROOT=/run/user/1000

# Local receiver and reverse tunnel endpoints must stay loopback-only.
PUMP_RELAY_LOCAL_LISTEN_URL=tcp://127.0.0.1:19097
PUMP_RELAY_REVERSE_TUNNEL_REMOTE=tcp://127.0.0.1:19097
PUMP_RELAY_REVERSE_TUNNEL_LOCAL=tcp://127.0.0.1:19097

# Optional local env file containing R2/provider credentials for local preflight.
# If omitted, the preflight will use already-loaded shell env, ../pump-launch-quant.env,
# or .codex_runtime_env/relay_r2.env if present.
# PUMP_RELAY_R2_ENV_FILE=/absolute/path/to/local/r2.env

# Expected latest_run_id for safety checks.
# EXPECTED_MATERIAL_LATEST_RUN_ID=material-candidate-hunter-...
