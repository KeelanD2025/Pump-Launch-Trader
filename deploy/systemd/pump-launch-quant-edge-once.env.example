# Environment variables for the edge collector systemd units.
# Copy values into /home/ubuntu/pump-launch-quant.env on the VPS.
# Do not put secrets in this file.

GRPC_URL=
GEYSER_AUTH_TOKEN=
R2_ACCOUNT_ID=
R2_DATASET_BUCKET=
R2_REPORTS_BUCKET=
R2_CALIBRATION_BUCKET=
R2_PROVIDER_COMPAT_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
