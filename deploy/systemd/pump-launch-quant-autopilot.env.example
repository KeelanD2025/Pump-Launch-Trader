# Copy to ~/.config/pump-launch-quant-autopilot.env and fill locally.
# chmod 600 this file after copying and never commit the populated version.
# Rotate any pasted or exposed credentials before production use.
# Use scoped R2 S3 credentials for uploads; CF_API_TOKEN is optional and only for bucket management.
GEYSER_ENDPOINT=
GEYSER_AUTH_TOKEN=
SHREDSTREAM_ENDPOINT=
SHREDSTREAM_AUTH_TOKEN=
CF_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DATASET_BUCKET=
R2_REPORTS_BUCKET=
R2_CALIBRATION_BUCKET=
R2_PROVIDER_COMPAT_BUCKET=
R2_ENDPOINT=
R2_MANAGED_PREFIX=
# Optional provider label for reports.
PROVIDER_NAME=
